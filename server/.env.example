# Copy this file to ".env" and fill in real values. The real .env is gitignored.

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Node server
PORT=3000

# Image APIs (free tiers) — get keys at leonardo.ai and deepai.org
LEONARDO_API_KEY=your_key_here
DEEPAI_API_KEY=your_key_here

# Discord webhook for the Daily Reporter
# Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME
